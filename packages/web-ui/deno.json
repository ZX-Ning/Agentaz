{
    "name": "@agentaz/web-ui",
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "dom.asynciterable", "esnext"]
    },
    "exports": "./src/main.ts",
    "publish": false,
    "imports": {
        "@agentaz/protocol": "../protocol/mod.ts",
        "vite": "npm:vite@^6.3.0",
        "vue-tsc": "npm:vue-tsc@^3.0.0",
        "vue": "npm:vue@^3.5.0",
        "@vitejs/plugin-vue": "npm:@vitejs/plugin-vue@^5.2.0",
        "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.0",
        "reka-ui": "npm:reka-ui@^2.10.1",
        "lucide-vue-next": "npm:lucide-vue-next@^0.468.0",
        "vue-sonner": "npm:vue-sonner@^2.0.8",
        "@comark/vue": "npm:@comark/vue@^0.4.0",
        "katex": "npm:katex@^0.16.47",
        "@fontsource-variable/ibm-plex-sans": "npm:@fontsource-variable/ibm-plex-sans@^5.2.8",
        "tailwindcss": "npm:tailwindcss@^4.3.0"
    },
    "tasks": {
        "dev": "deno run -A npm:vite --host 127.0.0.1",
        "build": "deno run -A npm:vite build",
        "typecheck": "deno run -A npm:vue-tsc --noEmit -p tsconfig.json && deno check ."
    }
}
