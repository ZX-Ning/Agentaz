{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "noEmit": true,
        "ignoreDeprecations": "6.0",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": [],
        "baseUrl": ".",
        "paths": {
            "@agentaz/protocol": ["../protocol/mod.ts"]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.vue",
        "src/**/*.d.ts",
        "vite.config.ts"
    ],
    "references": []
}
